# awork API
AWORK_API_TOKEN=dein-bearer-token
AWORK_BASE_URL=https://api.awork.com/api/v1

# Anthropic API (Claude)
ANTHROPIC_API_KEY=dein-anthropic-api-key

# Middleware
PORT=3500
API_KEY=ein-sicherer-api-key-fuer-webhook-auth

# Optional: Logging
LOG_LEVEL=info

# Optional: Microsoft Graph E-Mail-Polling
# Wenn gesetzt, pollt die Middleware automatisch nach E-Mails mit
# der Kategorie "→ awork" und verarbeitet sie.
# Azure AD App-Registrierung nötig (Application Permission: Mail.ReadWrite)
MS_TENANT_ID=deine-azure-ad-tenant-id
MS_CLIENT_ID=deine-app-client-id
MS_CLIENT_SECRET=dein-app-client-secret
MS_USER_EMAIL=deine@email.de
MS_POLL_INTERVAL=180000
MS_TRIGGER_CATEGORY=→ awork
